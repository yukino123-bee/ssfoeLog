# CommuniFund Environment Configuration Template
# Copy this file to .env and configure for your environment

# Database Configuration
DB_HOST=localhost
DB_USER=communifund_user
DB_PASS=your_secure_password_here_min_16_chars
DB_NAME=communifund

# Application Settings
APP_ENV=production
APP_DEBUG=false
APP_URL=https://communifund.local

# SMS Configuration (Optional)
SMS_ENABLED=false
SMS_API_KEY=your_sms_api_key_here
SMS_SENDER_NAME=CommuniFund

# Email Configuration (Optional)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USER=your_email_user
MAIL_PASS=your_email_password
MAIL_FROM=noreply@communifund.local

# Security Settings
SESSION_TIMEOUT=1800
CSRF_TOKEN_LENGTH=64
MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW=900
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# File Upload Settings
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=pdf,doc,docx,jpg,jpeg,png,gif
UPLOAD_PATH=/uploads/

# Logging Settings
LOG_LEVEL=warning
LOG_PATH=/storage/logs/

# Security Headers
ENABLE_SECURITY_HEADERS=true
ENABLE_HSTS=true
CSP_ENABLED=true

# Features
ENABLE_2FA=false
ENABLE_API_RATE_LIMITING=true
ENABLE_AUDIT_LOGGING=true
